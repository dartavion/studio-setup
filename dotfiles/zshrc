## ── zsh basics ───────────────────────────────────────────────────────────────
# No framework: starship is the prompt, git aliases are defined below, and the
# autosuggestions/syntax-highlighting plugins are sourced directly. This is
# everything oh-my-zsh was actually providing here.

# Completion
autoload -Uz compinit && compinit -i
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'   # case-insensitive

# History
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE HIST_REDUCE_BLANKS INC_APPEND_HISTORY

# Sane interactive options
setopt AUTO_CD INTERACTIVE_COMMENTS
bindkey -e   # emacs keybindings (Ctrl-A / Ctrl-E / Ctrl-R …)

# zsh-autosuggestions (brew/apt). Candidate paths: Apple Silicon, Intel mac, Linux.
for _f in \
  /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh \
  /usr/local/share/zsh-autosuggestions/zsh-autosuggestions.zsh \
  /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh; do
  [ -f "$_f" ] && { source "$_f"; break; }
done
unset _f

## ── PATH helpers ─────────────────────────────────────────────────────────────

# user-local bin (scripts, pip installs, etc.)
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

# pnpm
export PNPM_HOME="$HOME/.local/share/pnpm"
export PATH="$PNPM_HOME:$PATH"

## ── language version managers ────────────────────────────────────────────────

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"

# pyenv
export PYENV_ROOT="$HOME/.pyenv"
if command -v pyenv &>/dev/null || [ -x "$PYENV_ROOT/bin/pyenv" ]; then
  export PATH="$PYENV_ROOT/bin:$PATH"
  eval "$(pyenv init -)"
fi

# go
[ -d "$HOME/go/bin" ] && export PATH="$HOME/go/bin:$PATH"
[ -d "/usr/local/go/bin" ] && export PATH="/usr/local/go/bin:$PATH"

## ── modern CLI replacements ──────────────────────────────────────────────────

# eza: better ls
if command -v eza &>/dev/null; then
  alias ls='eza --icons --group-directories-first'
  alias ll='eza -la --icons --group-directories-first --git'
  alias la='eza -a --icons --group-directories-first'
  alias tree='eza --tree --icons'
fi

# bat: better cat (Ubuntu/WSL installs as batcat)
if command -v bat &>/dev/null; then
  alias cat='bat --style=plain --pager=never'
  export BAT_THEME="Catppuccin Mocha"
elif command -v batcat &>/dev/null; then
  alias bat='batcat'
  alias cat='batcat --style=plain --pager=never'
  export BAT_THEME="Catppuccin Mocha"
fi

# fzf
[ -f "$HOME/.fzf.zsh" ] && source "$HOME/.fzf.zsh"
# fd: Ubuntu/WSL installs as fdfind
if command -v fdfind &>/dev/null && ! command -v fd &>/dev/null; then
  alias fd='fdfind'
fi
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git 2>/dev/null || fdfind --type f --hidden --follow --exclude .git 2>/dev/null || find . -type f'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_DEFAULT_OPTS="
  --color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8
  --color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc
  --color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8
"

# zoxide: better cd
command -v zoxide &>/dev/null && eval "$(zoxide init zsh)"

## ── git aliases ──────────────────────────────────────────────────────────────

alias g='git'
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gpl='git pull'
alias gd='git diff'
alias gco='git checkout'
alias gb='git branch'
alias gl='git log --oneline --graph --decorate --all'

## ── dev shortcuts ────────────────────────────────────────────────────────────

alias nv='nvim'
alias v='nvim'
alias c='claude'
alias ..='cd ..'
alias ...='cd ../..'

# open current dir in WezTerm
alias wt='wezterm start --cwd .'

## ── machine-specific overrides ───────────────────────────────────────────────

# Machine-specific env vars, secrets, and PATH additions go in ~/.zshrc.local
# That file is never committed. Copy dotfiles/zshrc.local.template to get started.
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"

## ── prompt ───────────────────────────────────────────────────────────────────

# Starship prompt
command -v starship &>/dev/null && eval "$(starship init zsh)"

## ── syntax highlighting (must be the very last thing sourced) ─────────────────
# zsh-syntax-highlighting wraps every zle widget, so it has to load after
# everything else that defines widgets (fzf, starship, etc.).
for _f in \
  /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh \
  /usr/local/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh \
  /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh; do
  [ -f "$_f" ] && { source "$_f"; break; }
done
unset _f
